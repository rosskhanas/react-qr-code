{
  "name": "react-qr-code",
  "version": "2.0.21",
  "description": "A QR code generator for React and React Native.",
  "keywords": [
    "code",
    "generator",
    "qr",
    "react",
    "react-native"
  ],
  "author": {
    "name": "Ross Khanas",
    "email": "rtkhanas@gmail.com"
  },
  "scripts": {
    "demo-web-watch": "babel ./src --out-dir=./demo/src/lib --watch",
    "demo": "cd demo && npm run start",
    "demo:build": "cd demo && npx expo export -p web",
    "demo:deploy": "gh-pages -d demo/dist",
    "clean": "rimraf lib",
    "lint": "biome check --write ./src",
    "build": "npm run clean && babel src --out-dir lib",
    "release": "release-it"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:rosskhanas/react-qr-code.git"
  },
  "files": [
    "lib",
    "types"
  ],
  "main": "lib/index.js",
  "types": "types/index.d.ts",
  "dependencies": {
    "prop-types": "^15.8.1",
    "qr.js": "0.0.0"
  },
  "peerDependencies": {
    "react": "*"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@release-it/conventional-changelog": "^10.0.6",
    "gh-pages": "^6.3.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3"
  }
}
